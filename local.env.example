# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Base64 encoded Firebase service account credentials
FIREBASE_CREDENTIALS_B64=your_firebase_credentials_base64_here

# ========================================
# WAAFI PAYMENT API CONFIGURATION
# ========================================
WAAFI_API_KEY=your_waafi_api_key
WAAFI_API_USER_ID=your_waafi_user_id
WAAFI_MERCHANT_UID=your_waafi_merchant_uid
WAAFI_URL=https://api.waafipay.com/asm

# ========================================
# HEYCHARGE API CONFIGURATION
# ========================================
HEYCHARGE_API_KEY=your_heycharge_api_key
HEYCHARGE_DOMAIN=https://openapi.heycharge.global

# ========================================
# APPSPHERE / BESITER CABINET CONFIGURATION
# ========================================
# AppSphere cabinets need a bridge that can publish MQTT commands and read cabinet telemetry.
# Keep this empty until the bridge is tested with a real cabinet.
APPSPHERE_BRIDGE_URL=
APPSPHERE_BRIDGE_SECRET=

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000

# ========================================
# CUSTOM DOMAIN SETUP (Recommended)
# ========================================
# Configure all stations in ONE deployment using custom domains
# Each domain automatically detects its station number from the URL

# Station 58 - Castello Taleex
STATION_58_IMEI=WSEP161721195358

# Station 59 - Castello Boondhere
STATION_59_IMEI=WSEP161741066502

# Station 60 - Java Taleex
STATION_60_IMEI=WSEP161741066503

# Station 61 - Java Airport
STATION_61_IMEI=WSEP161741066504

# Station 62 - Dilek Somalia
STATION_62_IMEI=WSEP161741066505

# Add more stations as needed:
# STATION_63_IMEI=your_station_imei
# STATION_64_IMEI=your_station_imei

# AppSphere/Besiter station example:
# STATION_63_PROVIDER=appsphere
# STATION_63_CABINET_SN=your_appsphere_cabinet_sn

# ========================================
# FALLBACK CONFIGURATION (Optional)
# ========================================
# Use these if you're NOT using custom domains
# Only needed for single-station deployments or local development

# STATION_CODE=58
# STATION_IMEI=WSEP161721195358
